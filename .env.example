# novel2script 配置示例
# 复制此文件为 .env 并填入实际值：
#   cp .env.example .env

# LLM API 密钥（必填）
# Anthropic: https://console.anthropic.com/
#   格式: sk-ant-api03-xxxxxxxxxxxxx
# OpenAI 兼容: https://platform.openai.com/
#   格式: sk-xxxxxxxxxxxxxxxxxxxxxxxx
NOVEL2SCRIPT_API_KEY=sk-your-api-key-here

# LLM 提供商: anthropic | openai
NOVEL2SCRIPT_PROVIDER=anthropic

# 模型名称
# Anthropic 推荐: claude-sonnet-4-20250514
# OpenAI 兼容推荐: gpt-4o
NOVEL2SCRIPT_MODEL=claude-sonnet-4-20250514

# API 基础 URL（留空使用提供商默认地址）
# NOVEL2SCRIPT_BASE_URL=

# 并行 LLM 调用数（默认 5）
NOVEL2SCRIPT_PARALLEL=5

# 缓存目录（默认 ~/.novel2script/cache）
# NOVEL2SCRIPT_CACHE_DIR=
